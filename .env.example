# .env.example — copy to .env.local for local development
# Production values are set via install.sh or your hosting platform's env config.

# ── App Identity ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Chat
NEXT_PUBLIC_APP_SHORT_NAME=Chat
NEXT_PUBLIC_APP_DESCRIPTION=Your personal AI assistant

# Optional: brief domain description injected into the system prompt.
# e.g. "online food delivery service", "handyman booking platform"
# APP_PERSONA_CONTEXT=

# ── Locale ───────────────────────────────────────────────────────────────────
# Default language when the user has no preference set.
# Available: en | id | kr | jp | es | zh | de | nl | fr | it
APP_LOCALE=en

# ── Database ─────────────────────────────────────────────────────────────────

# SQLite — default for local dev, no setup required
DATABASE_URL="file:./dev.db"
DATABASE_PROVIDER=sqlite

# PostgreSQL / Aurora PG / Neon / Supabase / RDS PG
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_PROVIDER=postgresql

# MySQL / MariaDB / Aurora MySQL / PlanetScale / RDS MySQL
# DATABASE_URL=mysql://user:password@host:3306/dbname
# DATABASE_PROVIDER=mysql

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Must match NEXT_PUBLIC_APP_URL — used by Better Auth to build email links
# (verification, password reset). Wrong value = broken links in emails.
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Auto-detected from the first API key present below.
# Set LLM_PROVIDER to force a specific provider regardless of which keys are set.
# LLM_PROVIDER=openrouter

# OpenRouter — 100+ models, free tier available (recommended for getting started)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_RESOURCE_NAME=your-resource       # part before .openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Azure AI Foundry
# AZURE_FOUNDRY_API_KEY=
# AZURE_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com/
# AZURE_FOUNDRY_MODEL=gpt-4o-mini

# AWS Bedrock
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0

# Google Vertex AI
# GOOGLE_VERTEX_PROJECT=your-gcp-project
# GOOGLE_VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.0-flash

# Fireworks AI
# FIREWORKS_API_KEY=
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# xAI Grok
# XAI_API_KEY=
# XAI_MODEL=grok-3-mini

# ── Image Storage / Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://assets.yourdomain.com

# Set to true if an external MCP server stores R2 image URLs from this app.
# When enabled, R2 objects are NOT deleted when conversations are deleted or
# auto-cleaned up — URLs remain accessible. Storage grows indefinitely; manage
# via R2 bucket lifecycle rules if needed. Default: false (images deleted with conversations).
# PRESERVE_IMAGES=true

# ── Background Jobs / Trigger.dev ────────────────────────────────────────────
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxx

# ── Email / Resend ───────────────────────────────────────────────────────────
# Leave empty to disable email verification entirely.
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com

# ── Error Tracking / Sentry ──────────────────────────────────────────────────
# Leave empty to disable Sentry in this environment.
# Recommended: enable in staging and production only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=    # needed only for source map uploads in CI/CD builds

# ── Location Sharing ─────────────────────────────────────────────────────────
NEXT_PUBLIC_LOCATION_MODE=v1    # v1 = browser geolocation only | v2 = Google Maps

# Required for v2:
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=    # client key — restrict to HTTP referrer + Places API
# GOOGLE_MAPS_API_KEY=                # server key — restrict to server IP + Distance Matrix API
# NEXT_PUBLIC_GOOGLE_MAPS_REGION=     # optional: ISO 3166-1 alpha-2 e.g. US, ID, JP

# ── MCP Server (optional — choose ONE or leave both empty) ───────────────────
# Setting both MCP_URL and MCP_APPS_URL at the same time returns a 500 error.

# Option A: any backend (Rails, Laravel, Spring…) — tools only
# MCP_URL=
# MCP_TOKEN=

# Option B: TypeScript MCP Apps server — tools + embedded UI
# MCP_APPS_URL=
# MCP_APPS_TOKEN=

# JWT for user identity propagation to the MCP server (optional)
# MCP_JWT_SECRET=

# ── Branding / PWA ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_THEME_COLOR=#ffffff    # browser toolbar color on mobile (PWA)
NEXT_PUBLIC_APP_BG_COLOR=#ffffff       # splash screen background on PWA launch

# ── Icons (optional — falls back to files in public/ if not set) ─────────────
# Accepts absolute URLs or relative paths (e.g. /icon.png from public/).
# APP_FAVICON_URL=/favicon.ico
# APP_ICON_SVG_URL=/icon.svg
# APP_ICON_192_URL=/icon-192.png
# APP_ICON_512_URL=/icon-512.png
# APP_APPLE_TOUCH_ICON_URL=/apple-touch-icon.png    # 180×180 PNG

# ── Open Graph / Social ──────────────────────────────────────────────────────
# APP_OG_IMAGE_URL=/og.png                           # 1200×630 PNG
# APP_TWITTER_CARD=summary_large_image               # summary | summary_large_image
# APP_TWITTER_SITE=@yourhandle

# ── Chat UI ──────────────────────────────────────────────────────────────────
# Adds a help button to the chat header linking to your help centre.
# NEXT_PUBLIC_APP_HELP_URL=https://help.yourdomain.com

# ── Analytics ────────────────────────────────────────────────────────────────
# Leave empty to disable Google Tag Manager entirely.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXX

# ── Redis (optional) ─────────────────────────────────────────────────────────
# Enables a shared sliding-window rate limiter across multiple app replicas.
# Leave unset for single-instance deployments — falls back to in-memory.
# Supports any Redis-compatible host: self-hosted, AWS ElastiCache, Upstash, etc.
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://user:token@hostname:6380   # Upstash / TLS

# ── Dev / Tunnels ────────────────────────────────────────────────────────────
# Comma-separated allowed origins for ngrok / localtunnel in development.
# Leave empty when developing on localhost only.
# ALLOWED_DEV_ORIGINS=https://xxxx.ngrok-free.app
